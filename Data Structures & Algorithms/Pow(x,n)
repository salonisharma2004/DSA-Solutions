#do not use the function for the power calculation 
#optimised 

class Solution {
    public double myPow(double x, int n) {

        long num = n;

        if (num < 0) {
            x = 1 / x;
            num = -num;
        }

        double ans = 1.0;

        while (num > 0) {
            if (num % 2 == 1) {
                ans *= x;
            }

            x =x*x;
            num= num/2;
        }

        return ans;
    }
}
