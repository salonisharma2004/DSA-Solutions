class Solution {
    public int majorityElement(int[] nums) {
        int c=0;
        int k=0;
        for(int i :nums)
        {
            if(c==0)
            {
                k=i;
            }
            if(k==i)
            {
                c++;
            }
            else
            {
                c--;
            }
        }
        return k;
    }
}
